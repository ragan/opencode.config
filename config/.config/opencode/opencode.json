{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "autoupdate": true,
  "permission": {
    "skill": {
      "web-browsing": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "${OPENCODE_OLLAMA_URI}"
      },
      "models": {
        "janitor": {
          "id": "qwen3.5:27b",
          "name": "Code Janitor"
        },
        "glm": {
          "id": "glm4.7-flash-100k",
          "name": "GLM 4.7"
        },
        "qwen3.5:27b": {
          "id": "qwen3.5:27b",
          "name": "Qwen3.5 Coder 27B"
        },
        "qwen3-vl": {
          "id": "qwen3-vl:latest",
          "name": "Qwen3 Vision Language",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  }
}
